# Backend Server URLs (JSON format)
# Map each protocol to its backend server URL
BACKEND_URLS={"bitcoin-runes":"https://ord-backend.example.com","solana":"https://sol-backend.example.com"}

# Supported blockchain protocols (comma-separated)
SUPPORTED_PROTOCOLS=bitcoin-runes,solana

# API Authentication
WALLET_API_PASSWORD=your_secure_password_here

# Rate Limiting (requests per minute)
RATE_LIMIT=60

