## .env.example - environment variables for BLT-Rewards (BACON)
# Copy this file to .env and fill in your values
# Do NOT commit your real secrets.

# Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=

# Optional: API token for Wrangler if you prefer non-interactive login
WRANGLER_API_TOKEN=

# Bitcoin/Runes API configuration (for ord-server integration)
BITCOIN_RPC_URL=
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# Solana configuration
SOLANA_RPC_URL=
SOLANA_WALLET_ADDRESS=

# GitHub token for GitHub Actions integration
GITHUB_TOKEN=

# Optional: URL of the ord-server (running locally or in your network)
#   used by the worker to query wallet balance
ORD_SERVER_URL_MAINNET=http://localhost:9002

# Optional: main treasury wallet address (for display only)
TREASURY_ADDRESS=
